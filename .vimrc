set number
set ruler

set hlsearch
set nocompatible
set ttyfast
set showmatch
set ignorecase
set smartcase
set nostartofline
set showmode
set showcmd
set backup
set backupdir=~/.backup

"set listchars=trail: 

set scrolloff=3
"set mouse=a

syntax on
filetype plugin indent on
" set t_Co=256
" colorscheme blueshift

" set guifont=ProFontIIx:h14
